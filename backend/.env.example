# NetGeo backend configuration (copy to .env)
# Note: the app version is a code constant (app/core/config.py) and cannot be
# overridden from the environment — stale stamped values used to pin it forever.
APP_NAME=NetGeo
ENVIRONMENT=development

# --- Auth / secrets ----------------------------------------------------------
# SECRET_KEY signs sessions/JWTs. MUST be overridden in any non-dev environment
# with a strong random value, e.g.:  openssl rand -hex 32   (>= 32 bytes).
# Never commit the real value; in prod inject it via env-file or Docker secret.
SECRET_KEY=change-me-in-production

# Bootstrap admin account (Enterprise/RBAC).
# Leave NETGEO_ADMIN_PASSWORD empty to use first-run setup: the web UI will
# prompt you to create the admin password on first visit. Or set it here to
# seed the account non-interactively (headless/CI deployments).
# Passwords set/changed via the UI are persisted to NETGEO_AUTH_STORE and
# always take precedence over the env var on later restarts.
NETGEO_ADMIN_USER=admin
NETGEO_ADMIN_PASSWORD=
NETGEO_AUTH_STORE=~/.config/netgeo/auth.json

CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api

# PostgreSQL (production); the dev server defaults to an in-memory store.
DATABASE_URL=postgresql+asyncpg://netgeo:netgeo@localhost:5432/netgeo

# Redis — realtime state, WS pub/sub fan-out, simulation job queue.
REDIS_URL=redis://localhost:6379/0

# Simulation engine
SIM_MAX_NODES=5000
SIM_DEFAULT_SEED=0
SIM_MAX_EVENTS=5000000
SIM_METRIC_INTERVAL=1.0

# Emulation backend: null | containerlab | docker
EMULATION_BACKEND=null

ENABLE_HSTS=false
