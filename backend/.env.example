# NetForge backend configuration (copy to .env)
APP_NAME=NetForge
APP_VERSION=0.1
ENVIRONMENT=development
SECRET_KEY=change-me-in-production

CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api

# PostgreSQL (production); the dev server defaults to an in-memory store.
DATABASE_URL=postgresql+asyncpg://netforge:netforge@localhost:5432/netforge

# Redis — realtime state, WS pub/sub fan-out, simulation job queue.
REDIS_URL=redis://localhost:6379/0

# Simulation engine
SIM_MAX_NODES=5000
SIM_DEFAULT_SEED=0
SIM_MAX_EVENTS=5000000
SIM_METRIC_INTERVAL=1.0

# Emulation backend: null | containerlab | docker
EMULATION_BACKEND=null

ENABLE_HSTS=false
