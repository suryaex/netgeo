{#- Arista EOS config from a NetForge node + ForgeOS intent.
    EVPN-VXLAN aware (Arista is the canonical spine-leaf target). -#}
! Generated by NetForge config-gen — vendor: arista_eos
!
hostname {{ hostname }}
!
{% for vlan in vlans %}
vlan {{ vlan.id }}
   name {{ vlan.name | default('VLAN' ~ vlan.id) }}
!
{% endfor %}
{% for vrf in vrfs %}
vrf instance {{ vrf.name }}
!
{% endfor %}
{% for if in interfaces %}
interface {{ if.name }}
{%- if if.ip %}
   no switchport
   ip address {{ if.ip[0] }}
{%- endif %}
   mtu {{ if.mtu }}
   no shutdown
!
{% endfor %}
{% if ospf %}
router ospf {{ ospf.process_id | default(1) }}
   router-id {{ ospf.router_id }}
!
{% endif %}
{% if isis %}
router isis {{ isis.area_tag | default('CORE') }}
   net {{ isis.net }}
   is-type {{ isis.level | default('level-2') }}
!
{%- for ifc in isis.interfaces | default([]) %}
interface {{ ifc.name }}
   isis enable {{ isis.area_tag | default('CORE') }}
   isis metric {{ ifc.metric | default(10) }}
{%- if (ifc.circuit_type | default('broadcast')) == 'p2p' %}
   isis network point-to-point
{%- endif %}
!
{% endfor %}
{% endif %}
{% if bgp %}
router bgp {{ bgp.asn }}
   router-id {{ bgp.router_id }}
{%- for nb in bgp.neighbors | default([]) %}
   neighbor {{ nb.ip }} remote-as {{ nb.remote_as }}
{%- if nb.evpn | default(false) %}
   neighbor {{ nb.ip }} send-community extended
{%- endif %}
{%- endfor %}
{%- if evpn %}
   address-family evpn
{%- for nb in bgp.neighbors | default([]) %}
{%- if nb.evpn | default(false) %}
      neighbor {{ nb.ip }} activate
{%- endif %}
{%- endfor %}
{%- endif %}
{%- for vrf in vrfs %}
   vrf {{ vrf.name }}
      rd {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
      route-target import evpn {{ rt }}
      route-target import vpn-ipv4 {{ rt }}
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
      route-target export evpn {{ rt }}
      route-target export vpn-ipv4 {{ rt }}
{%- endfor %}
{%- endfor %}
!
{% endif %}
{% if evpn %}
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
{%- for vni in evpn.vnis | default([]) %}
   vxlan vlan {{ vni.vlan }} vni {{ vni.vni }}
{%- endfor %}
!
{% endif %}
{% for r in static_routes %}
ip route {{ r.prefix }} {{ r.next_hop }}
{% endfor %}
{% if fhrp %}
interface {{ fhrp.interface }}
   vrrp {{ fhrp.group }} priority-level {{ fhrp.priority | default(100) }}
   vrrp {{ fhrp.group }} ipv4 {{ fhrp.vip }}
{%- if fhrp.preempt | default(true) %}
   vrrp {{ fhrp.group }} preempt
{%- else %}
   no vrrp {{ fhrp.group }} preempt
{%- endif %}
   no shutdown
!
{% endif %}
end
