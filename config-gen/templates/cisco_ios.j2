{#- Cisco IOS / IOS-XE config from a NetGeo node + ForgeOS intent.
    Shared by ios/iosxr/nxos (close enough for v0.1 baseline). -#}
!
! Generated by NetGeo config-gen — vendor: cisco_ios
!
hostname {{ hostname }}
!
no ip domain-lookup
ip cef
!
{% for if in interfaces %}
interface {{ if.name }}
{%- if if.ip %}
 ip address {{ if.ip[0] | ip_only }} {{ if.ip[0] | cidr_to_mask }}
{%- else %}
 no ip address
{%- endif %}
 mtu {{ if.mtu }}
 no shutdown
!
{% endfor %}
{% if ospf %}
router ospf {{ ospf.process_id | default(1) }}
 router-id {{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
 network {{ net.prefix }} area {{ net.area }}
{%- endfor %}
!
{% endif %}
{% if isis %}
router isis
 net {{ isis.net }}
 is-type {{ isis.level | default('level-2') }}
!
{% for ifc in isis.interfaces | default([]) %}
interface {{ ifc.name }}
 ip router isis
 isis metric {{ ifc.metric | default(10) }}
{%- if (ifc.circuit_type | default('broadcast')) == 'p2p' %}
 isis network point-to-point
{%- endif %}
!
{% endfor %}
{% endif %}
{% if bgp %}
router bgp {{ bgp.asn }}
 bgp router-id {{ bgp.router_id }}
{%- for nb in bgp.neighbors | default([]) %}
 neighbor {{ nb.ip }} remote-as {{ nb.remote_as }}
{%- if nb.description %}
 neighbor {{ nb.ip }} description {{ nb.description }}
{%- endif %}
{%- endfor %}
 address-family ipv4 unicast
{%- for nb in bgp.neighbors | default([]) %}
  neighbor {{ nb.ip }} activate
{%- endfor %}
{%- for net in bgp.networks | default([]) %}
  network {{ net }}
{%- endfor %}
 exit-address-family
!
{% endif %}
{% for vrf in vrfs %}
vrf definition {{ vrf.name }}
 rd {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
 route-target import {{ rt }}
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
 route-target export {{ rt }}
{%- endfor %}
!
{% endfor %}
{% for r in static_routes %}
ip route {{ r.prefix }} {{ r.next_hop }}
{% endfor %}
{% if fhrp %}
interface {{ fhrp.interface }}
 standby {{ fhrp.group }} ip {{ fhrp.vip }}
 standby {{ fhrp.group }} priority {{ fhrp.priority | default(100) }}
{%- if fhrp.preempt | default(true) %}
 standby {{ fhrp.group }} preempt
{%- endif %}
!
{% endif %}
end
