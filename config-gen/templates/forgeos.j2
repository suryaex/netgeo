{#- ForgeOS native render — a clean, declarative echo of the node's intent.
    ForgeOS is NetGeo's own intent-based NOS (MASTER_SPEC §5): the device is
    configured by *intent*, and this view is the canonical, vendor-neutral form
    that every other template is compiled FROM. -#}
# ForgeOS intent — {{ hostname }}
# Generated by NetGeo config-gen — vendor: forgeos (native)
system:
  hostname: {{ hostname }}
  role: {{ kind }}
interfaces:
{% for if in interfaces %}
  - name: {{ if.name }}
    type: {{ if.type }}
    mtu: {{ if.mtu }}
{%- if if.ip %}
    addresses: [{{ if.ip | join(', ') }}]
{%- endif %}
{% endfor %}
{% if ospf %}
routing:
  ospf:
    router_id: {{ ospf.router_id }}
{% endif %}
{% if isis %}
{% if not ospf %}routing:{% endif %}
  isis:
    net: {{ isis.net }}
    level: {{ isis.level | default('level-2') }}
    interfaces: {{ isis.interfaces | default([]) | length }}
{% endif %}
{% if bgp %}
{% if not ospf and not isis %}routing:{% endif %}
  bgp:
    asn: {{ bgp.asn }}
    router_id: {{ bgp.router_id }}
    neighbors:
{%- for nb in bgp.neighbors | default([]) %}
      - peer: {{ nb.ip }}
        remote_as: {{ nb.remote_as }}
{%- endfor %}
{% endif %}
{% if vlans %}
vlans:
{%- for vlan in vlans %}
  - id: {{ vlan.id }}
    name: {{ vlan.name | default('VLAN' ~ vlan.id) }}
{%- endfor %}
{% endif %}
{% if vrfs %}
vrfs:
{%- for vrf in vrfs %}
  - name: {{ vrf.name }}
    rd: {{ vrf.rd }}
    import: [{{ vrf.import | default([]) | join(', ') }}]
    export: [{{ vrf.export | default([]) | join(', ') }}]
{%- endfor %}
{% endif %}
{% if evpn %}
overlay:
  evpn_vxlan:
    vnis: {{ evpn.vnis | default([]) | length }}
{% endif %}
