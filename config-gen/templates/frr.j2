{#- FRRouting (frr.conf / vtysh-style) config — the default open-source emul NOS.
    NOTE on fhrp: FRR has no native VRRP/HSRP daemon in frr.conf — VRRP on Linux+FRR
    is done via the separate `keepalived` package/config, not vtysh. We deliberately
    do NOT render `fhrp` here; see config-gen/README.md §3 "FRR + keepalived" for the
    documented integration approach instead of forcing it into this template. -#}
! Generated by NetGeo config-gen — vendor: frr
frr version 9.1
frr defaults traditional
hostname {{ hostname }}
!
{% for vrf in vrfs %}
vrf {{ vrf.name }}
 exit-vrf
!
{% endfor %}
{% for if in interfaces %}
interface {{ if.name }}
{%- if if.ip %}
 ip address {{ if.ip[0] }}
{%- endif %}
 mtu {{ if.mtu }}
!
{% endfor %}
{% if ospf %}
router ospf
 ospf router-id {{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
 network {{ net.prefix }} area {{ net.area }}
{%- endfor %}
!
{% endif %}
{% if isis %}
router isis NETGEO
 net {{ isis.net }}
 is-type {{ isis.level | default('level-2') }}
!
{%- for ifc in isis.interfaces | default([]) %}
interface {{ ifc.name }}
 ip router isis NETGEO
 isis metric {{ ifc.metric | default(10) }}
{%- if (ifc.circuit_type | default('broadcast')) == 'p2p' %}
 isis network point-to-point
{%- endif %}
!
{% endfor %}
{% endif %}
{% if bgp %}
router bgp {{ bgp.asn }}
 bgp router-id {{ bgp.router_id }}
{%- for nb in bgp.neighbors | default([]) %}
 neighbor {{ nb.ip }} remote-as {{ nb.remote_as }}
{%- endfor %}
 address-family ipv4 unicast
{%- for nb in bgp.neighbors | default([]) %}
  neighbor {{ nb.ip }} activate
{%- endfor %}
{%- for net in bgp.networks | default([]) %}
  network {{ net }}
{%- endfor %}
 exit-address-family
{%- if evpn %}
 address-family l2vpn evpn
{%- for nb in bgp.neighbors | default([]) %}
{%- if nb.evpn | default(false) %}
  neighbor {{ nb.ip }} activate
{%- endif %}
{%- endfor %}
  advertise-all-vni
 exit-address-family
{%- endif %}
!
{% endif %}
{% if bgp %}
{% for vrf in vrfs %}
router bgp {{ bgp.asn }} vrf {{ vrf.name }}
 address-family ipv4 unicast
  rd vpn export {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
  route-target import {{ rt }}
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
  route-target export {{ rt }}
{%- endfor %}
 exit-address-family
!
{% endfor %}
{% endif %}
{% for r in static_routes %}
ip route {{ r.prefix }} {{ r.next_hop }}
{% endfor %}
line vty
!
