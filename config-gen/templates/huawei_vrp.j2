{#- Huawei VRP (Versatile Routing Platform) config from a NetForge node + ForgeOS intent.
    Covers baseline: sysname, interfaces, OSPF, IS-IS, BGP, static routes, VRFs. -#}
#
# Generated by NetForge config-gen — vendor: vrp (Huawei VRP)
#
sysname {{ hostname }}
#
{% for if in interfaces %}
interface {{ if.name }}
{%- if if.ip %}
 ip address {{ if.ip[0] | ip_only }} {{ if.ip[0] | cidr_to_mask }}
{%- else %}
 undo ip address
{%- endif %}
 undo shutdown
#
{% endfor %}
{% if ospf %}
ospf {{ ospf.process_id | default(1) }} router-id {{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
 area {{ net.area }}
  network {{ net.prefix }}
{%- endfor %}
#
{% endif %}
{% if isis %}
isis {{ ospf.process_id | default(1) if ospf else 1 }}
 network-entity {{ isis.net }}
 is-level {{ isis.level | default('level-2') }}
#
{% endif %}
{% if bgp %}
bgp {{ bgp.asn }}
 router-id {{ bgp.router_id }}
{%- for nb in bgp.neighbors | default([]) %}
 peer {{ nb.ip }} as-number {{ nb.remote_as }}
{%- if nb.description %}
 peer {{ nb.ip }} description {{ nb.description }}
{%- endif %}
{%- endfor %}
 #
 ipv4-family unicast
{%- for nb in bgp.neighbors | default([]) %}
  peer {{ nb.ip }} enable
{%- endfor %}
{%- for net in bgp.networks | default([]) %}
  network {{ net }}
{%- endfor %}
 #
#
{% endif %}
{% for r in static_routes %}
ip route-static {{ r.prefix }} {{ r.next_hop }}
{% endfor %}
{% for vrf in vrfs %}
ip vpn-instance {{ vrf.name }}
 route-distinguisher {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
 vpn-target {{ rt }} import-extcommunity
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
 vpn-target {{ rt }} export-extcommunity
{%- endfor %}
#
{% endfor %}
{% for vlan in vlans %}
vlan {{ vlan.id }}
 name {{ vlan.name | default('VLAN' ~ vlan.id) }}
#
{% endfor %}
return
