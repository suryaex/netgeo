{#- Juniper Junos (set-style) config from a NetForge node + ForgeOS intent. -#}
## Generated by NetForge config-gen — vendor: junos
set system host-name {{ hostname }}
{% for if in interfaces %}
{%- if if.ip %}
set interfaces {{ if.name }} unit 0 family inet address {{ if.ip[0] }}
{%- else %}
set interfaces {{ if.name }} unit 0
{%- endif %}
set interfaces {{ if.name }} mtu {{ if.mtu }}
{% endfor %}
{% if ospf %}
set protocols ospf router-id {{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
set protocols ospf area {{ net.area }} interface {{ net.interface | default('all') }}
{%- endfor %}
{% endif %}
{% if isis %}
{%- set isis_level = isis.level | default('level-2') %}
set interfaces lo0 unit 0 family iso address {{ isis.net }}
set protocols isis level 1 disable
set protocols isis level 2 disable
{%- if isis_level == 'level-1' %}
delete protocols isis level 1 disable
{%- elif isis_level == 'level-1-2' %}
delete protocols isis level 1 disable
delete protocols isis level 2 disable
{%- else %}
delete protocols isis level 2 disable
{%- endif %}
set protocols isis interface lo0.0 passive
{%- for ifc in isis.interfaces | default([]) %}
set protocols isis interface {{ ifc.name }} level {{ '1' if isis_level == 'level-1' else '2' }} metric {{ ifc.metric | default(10) }}
{%- if (ifc.circuit_type | default('broadcast')) == 'p2p' %}
set protocols isis interface {{ ifc.name }} point-to-point
{%- endif %}
{%- endfor %}
{% endif %}
{% if bgp %}
set routing-options autonomous-system {{ bgp.asn }}
set routing-options router-id {{ bgp.router_id }}
{%- for nb in bgp.neighbors | default([]) %}
set protocols bgp group ext neighbor {{ nb.ip }} peer-as {{ nb.remote_as }}
{%- if nb.description %}
set protocols bgp group ext neighbor {{ nb.ip }} description "{{ nb.description }}"
{%- endif %}
{%- endfor %}
{% endif %}
{% for vrf in vrfs %}
set routing-instances {{ vrf.name }} instance-type vrf
set routing-instances {{ vrf.name }} route-distinguisher {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
set routing-instances {{ vrf.name }} vrf-import {{ rt }}
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
set routing-instances {{ vrf.name }} vrf-export {{ rt }}
{%- endfor %}
{% endfor %}
{% for r in static_routes %}
set routing-options static route {{ r.prefix }} next-hop {{ r.next_hop }}
{% endfor %}
{% if fhrp %}
set interfaces {{ fhrp.interface }} unit 0 family inet address {{ fhrp.local_ip | default('0.0.0.0/24') }} vrrp-group {{ fhrp.group }} virtual-address {{ fhrp.vip }}
set interfaces {{ fhrp.interface }} unit 0 family inet address {{ fhrp.local_ip | default('0.0.0.0/24') }} vrrp-group {{ fhrp.group }} priority {{ fhrp.priority | default(100) }}
{% endif %}
