{#- MikroTik RouterOS (script-style) config from a NetGeo node + intent.
    NOTE: RouterOS has no native IS-IS daemon, so `isis` intent is intentionally
    not rendered here (vendor capability gap, not a template omission — see
    config-gen/README.md §3). -#}
# Generated by NetGeo config-gen — vendor: mikrotik_routeros
/system identity set name={{ hostname }}
{% for vlan in vlans %}
/interface vlan add name=vlan{{ vlan.id }} vlan-id={{ vlan.id }} interface=bridge comment="{{ vlan.name | default('VLAN' ~ vlan.id) }}"
{% endfor %}
{% for vrf in vrfs %}
/ip vrf add name={{ vrf.name }} interfaces="" route-distinguisher={{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
/routing bgp vrf-import-rt add vrf={{ vrf.name }} route-target={{ rt }}
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
/routing bgp vrf-export-rt add vrf={{ vrf.name }} route-target={{ rt }}
{%- endfor %}
{% endfor %}
{% for if in interfaces %}
{%- if if.ip %}
/ip address add address={{ if.ip[0] }} interface={{ if.name }}
{%- endif %}
{% endfor %}
{% if evpn %}
{%- for vni in evpn.vnis | default([]) %}
/interface vxlan add name=vxlan{{ vni.vni }} vni={{ vni.vni }} interface=bridge
/interface bridge port add bridge=bridge interface=vxlan{{ vni.vni }} pvid={{ vni.vlan }}
{%- endfor %}
{% endif %}
{% if ospf %}
/routing ospf instance add name=default version=2 router-id={{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
/routing ospf network add network={{ net.prefix }} area={{ net.area_name | default('backbone') }}
{%- endfor %}
{% endif %}
{% if bgp %}
/routing bgp connection
{%- for nb in bgp.neighbors | default([]) %}
add name=peer-{{ loop.index }} remote.address={{ nb.ip }} remote.as={{ nb.remote_as }} as={{ bgp.asn }} router-id={{ bgp.router_id }}
{%- endfor %}
{% endif %}
{% for r in static_routes %}
/ip route add dst-address={{ r.prefix }} gateway={{ r.next_hop }}
{% endfor %}
{% if fhrp %}
/interface vrrp add name=vrrp{{ fhrp.group }} interface={{ fhrp.interface }} vrid={{ fhrp.group }} priority={{ fhrp.priority | default(100) }}
/ip address add address={{ fhrp.vip }}/32 interface=vrrp{{ fhrp.group }}
{% endif %}
