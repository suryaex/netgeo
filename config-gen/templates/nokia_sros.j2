{#- Nokia SR OS (MD-CLI flat-path style) config from a NetForge node + ForgeOS intent.
    SR OS uses a hierarchical /configure path syntax in its MD-CLI.
    This covers the baseline: hostname, interfaces, OSPF, IS-IS, BGP, static routes. -#}
# Generated by NetForge config-gen — vendor: sros (Nokia SR OS)
/configure system name "{{ hostname }}"
/configure system location "NetForge-managed"
{% for if in interfaces %}
/configure router interface "{{ if.name }}"
{%- if if.ip %}
/configure router interface "{{ if.name }}" ipv4 primary address {{ if.ip[0] | ip_only }} prefix-length {{ if.ip[0] | prefixlen }}
{%- endif %}
/configure router interface "{{ if.name }}" no shutdown
{% endfor %}
{% if ospf %}
/configure router ospf 0 router-id {{ ospf.router_id }}
{%- for net in ospf.networks | default([]) %}
/configure router ospf 0 area {{ net.area }} interface "{{ net.interface | default('system') }}" no shutdown
{%- endfor %}
/configure router ospf 0 no shutdown
{% endif %}
{% if isis %}
/configure router isis 0 system-id {{ isis.net | default('49.0001.0000.0000.0001.00') }}
/configure router isis 0 level-capability {{ isis.level | default('level-2') }}
/configure router isis 0 no shutdown
{% endif %}
{% if bgp %}
/configure router bgp router-id {{ bgp.router_id }}
/configure router bgp autonomous-system {{ bgp.asn }}
{%- for nb in bgp.neighbors | default([]) %}
/configure router bgp neighbor {{ nb.ip }} peer-as {{ nb.remote_as }}
{%- if nb.description %}
/configure router bgp neighbor {{ nb.ip }} description "{{ nb.description }}"
{%- endif %}
{%- endfor %}
/configure router bgp no shutdown
{% endif %}
{% for r in static_routes %}
/configure router static-routes route {{ r.prefix }} next-hop {{ r.next_hop }}
{% endfor %}
{% for vrf in vrfs %}
/configure service vprn {{ vrf.name | replace(' ','-') }} customer 1
/configure service vprn {{ vrf.name | replace(' ','-') }} route-distinguisher {{ vrf.rd }}
{%- for rt in vrf.import | default([]) %}
/configure service vprn {{ vrf.name | replace(' ','-') }} vrf-import policy "import-{{ rt | replace(':','-') }}"
{%- endfor %}
/configure service vprn {{ vrf.name | replace(' ','-') }} no shutdown
{% endfor %}
