{#- VyOS (set-style) config from a NetGeo node + ForgeOS intent. -#}
# Generated by NetGeo config-gen — vendor: vyos
set system host-name '{{ hostname }}'
{% for vlan in vlans %}
set interfaces ethernet eth0 vif {{ vlan.id }} description '{{ vlan.name | default('VLAN' ~ vlan.id) }}'
{% endfor %}
{% for vrf in vrfs %}
set vrf name {{ vrf.name }} table {{ vrf.table | default(100 + loop.index) }}
set vrf name {{ vrf.name }} protocols bgp route-distinguisher '{{ vrf.rd }}'
{%- for rt in vrf.import | default([]) %}
set vrf name {{ vrf.name }} protocols bgp address-family ipv4-unicast route-target import '{{ rt }}'
{%- endfor %}
{%- for rt in vrf.export | default([]) %}
set vrf name {{ vrf.name }} protocols bgp address-family ipv4-unicast route-target export '{{ rt }}'
{%- endfor %}
{% endfor %}
{% for if in interfaces %}
{%- if if.ip %}
set interfaces ethernet {{ if.name }} address '{{ if.ip[0] }}'
{%- endif %}
set interfaces ethernet {{ if.name }} mtu '{{ if.mtu }}'
{% endfor %}
{% if ospf %}
set protocols ospf parameters router-id '{{ ospf.router_id }}'
{%- for net in ospf.networks | default([]) %}
set protocols ospf area '{{ net.area }}' network '{{ net.prefix }}'
{%- endfor %}
{% endif %}
{% if isis %}
set protocols isis net '{{ isis.net }}'
set protocols isis level-capability '{{ isis.level | default('level-2') }}'
{%- for ifc in isis.interfaces | default([]) %}
set interfaces ethernet {{ ifc.name }} ip router isis
set protocols isis interface {{ ifc.name }} metric '{{ ifc.metric | default(10) }}'
{%- if (ifc.circuit_type | default('broadcast')) == 'p2p' %}
set protocols isis interface {{ ifc.name }} network point-to-point
{%- endif %}
{%- endfor %}
{% endif %}
{% if bgp %}
set protocols bgp system-as '{{ bgp.asn }}'
set protocols bgp parameters router-id '{{ bgp.router_id }}'
{%- for nb in bgp.neighbors | default([]) %}
set protocols bgp neighbor {{ nb.ip }} remote-as '{{ nb.remote_as }}'
{%- if nb.evpn | default(false) %}
set protocols bgp neighbor {{ nb.ip }} address-family l2vpn-evpn
{%- endif %}
{%- endfor %}
{% endif %}
{% if evpn %}
set interfaces vxlan vxlan0 source-interface 'lo'
{%- for vni in evpn.vnis | default([]) %}
set interfaces vxlan vxlan0 vni-to-vlan vni {{ vni.vni }} vlan {{ vni.vlan }}
{%- endfor %}
{% endif %}
{% for r in static_routes %}
set protocols static route {{ r.prefix }} next-hop '{{ r.next_hop }}'
{% endfor %}
{% if fhrp %}
set high-availability vrrp group VRRP-{{ fhrp.group }} interface '{{ fhrp.interface }}'
set high-availability vrrp group VRRP-{{ fhrp.group }} vrid '{{ fhrp.group }}'
set high-availability vrrp group VRRP-{{ fhrp.group }} address '{{ fhrp.vip }}'
set high-availability vrrp group VRRP-{{ fhrp.group }} priority '{{ fhrp.priority | default(100) }}'
{%- if not (fhrp.preempt | default(true)) %}
set high-availability vrrp group VRRP-{{ fhrp.group }} no-preempt
{%- endif %}
{% endif %}
