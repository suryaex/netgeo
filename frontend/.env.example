# NetForge frontend env. Copy to `.env.local` for overrides.
# In dev these are usually left unset — Vite proxies /api and /ws to the backend
# (see vite.config.ts), so the browser talks to a single origin.

# Backend origin used by the Vite dev proxy.
VITE_BACKEND_ORIGIN=http://localhost:8000

# Override only if the frontend is served separately from the API/WS.
# VITE_API_BASE=https://api.netforge.example/api
# VITE_WS_BASE=wss://api.netforge.example
