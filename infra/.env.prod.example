# NetForge — variabel produksi (salin ke infra/.env.prod, JANGAN commit yang asli)
# Dipakai: docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.prod up -d

# --- PostgreSQL ---
POSTGRES_USER=netforge
POSTGRES_PASSWORD=ganti-dengan-password-kuat
POSTGRES_DB=netforge

# --- Backend ---
SECRET_KEY=ganti-dengan-random-32+char
CORS_ORIGINS=https://netforge.example.com
EMULATION_BACKEND=null            # null | containerlab | docker

# --- Image (registry) ---
BACKEND_IMAGE=ghcr.io/netforge/backend:latest
FRONTEND_IMAGE=ghcr.io/netforge/frontend:latest

# --- Networking ---
HTTP_PORT=80
