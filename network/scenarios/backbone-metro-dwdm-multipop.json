    ],
    "expected_outcomes": [
      "packet_loss_window_ms < 50 (jika BFD+FRR aktif) atau < 5000 (tanpa FRR, full IGP reconverge)",
      "no_permanent_blackhole_after_reconverge == true",
      "all_other_pop_pairs_unaffected == true"
    ]
  }
