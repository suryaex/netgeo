  "scenario": {
    "id": "scn-test-backbone-dwdm-01",
    "project_id": "scn-backbone-dwdm-01",
    "name": "Fiber-cut Ring-A + reroute Ring-B",
    "steps": [
      "Kirim trafik baseline iperf 20Gbps jkt -> mks selama 60s",
      "Putuskan link lnk-jkt-bdg-ringA pada t=30s (set status=down)",
      "Amati waktu reroute via Ring-B (bdg-sby-ringB + sby-mks-ringA) dan packet loss window",
