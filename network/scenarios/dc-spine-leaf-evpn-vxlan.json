    "name": "Leaf failure + ECMP rebalance + tenant isolation check",
    "steps": [
      "Generate trafik east-west antar server tenant-a (srv-01 <-> srv-05) line-rate 20Gbps",
      "Matikan dc1-pod1-leaf-01 (status=down) pada t=20s",
      "Amati srv-01 tetap reachable via leaf-02 (NIC kedua) dengan loss transient < 1s",
      "Kirim trafik dari tenant-b (srv-03) ke subnet tenant-a -- harus DROP (no route, VRF terpisah)",
      "Pulihkan leaf-01, amati ECMP kembali memakai 2 uplink ke leaf-01 setelah BGP underlay re-converge"
    ],
    "expected_outcomes": [
      "server_dual_homed_failover_loss_ms < 1000",
      "tenant_cross_vrf_traffic_blocked == true",
      "ecmp_path_deviation_pct < 15",
      "evpn_route_reconverge_s < 2"
    ]
  }
