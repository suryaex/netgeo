  "scenario": {
    "id": "scn-test-dci-01",
    "project_id": "scn-dci-sr-mpls-01",
    "name": "TI-LFA failover saat P-transit utama down",
    "steps": [
      "Bangun trafik replication DC1->DC3 (10 Gbps steady) lewat path default (PE-DCI-01 -> P-TRANSIT-01 -> P-TRANSIT-02 -> PE-DCI-02)",
      "Matikan dci-p-transit-01 pada t=30s",
      "Amati apakah trafik DC2 (yang access via p-transit-01) ikut terdampak -- DC2 hanya punya 1 jalur masuk ke core DCI",
      "Amati waktu reroute trafik DC1->DC3 (jika TI-LFA aktif vs tidak)",
      "Ukur RTT baru setelah reroute dan bandingkan terhadap threshold sync-replication (20ms)"
    ],
    "expected_outcomes": [
      "ti_lfa_failover_ms < 50",
      "dc2_isolated_during_ptransit01_outage == true (flagged as design risk, single path)",
      "dc1_dc3_traffic_survives_via_alternate_path == true",
      "post_failover_rtt_ms_reported == true"
    ]
  }
