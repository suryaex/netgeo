  "scenario": {
    "id": "scn-test-isp-bgp-01",
    "project_id": "scn-isp-bgp-rr-01",
    "name": "RR failover + route leak detection + upstream multihoming",
    "steps": [
      "Originate prefix CE-CORP-A (2x /24) dan CE-CORP-B (1x /24), tunggu propagasi ke seluruh PE via RR",
      "Matikan isp-rr-01, verifikasi semua PE tetap menerima update lewat isp-rr-02",
      "Simulasikan misconfig: PE-03 export rute upstream (community 65001:300) ke IX peer -- harus terdeteksi sebagai leak",
      "Putuskan lnk-edge01-upstream, verifikasi trafik reroute via PE-EDGE-02",
      "Putuskan lnk-pe01-cecorpa (primary CORP-A), verifikasi failover ke lnk-pe02-cecorpa"
    ],
    "expected_outcomes": [
      "rr_failover_route_loss == false",
      "route_leak_detected == true",
      "upstream_failover_convergence_s < 30",
      "ce_corp_a_failover_blackhole == false",
      "ce_corp_b_no_redundancy_flagged_as_design_risk == true"
    ]
  }
}
